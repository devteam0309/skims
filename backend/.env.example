# Server
NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=<AppName>

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<64-byte-hex-string>
# Short-lived access token; a separate 30-day refresh token (DB-backed, revocable) handles session continuity
JWT_EXPIRE=15m
JWT_COOKIE_EXPIRE=7

# Email (Nodemailer / Gmail App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=<your-email@gmail.com>
SMTP_PASSWORD=<gmail-app-password>
FROM_EMAIL=noreply@skims.gov.ph
FROM_NAME=SKIMS Platform

# Cloudinary — required for file storage (get credentials at cloudinary.com)
CLOUDINARY_CLOUD_NAME=<cloud-name>
CLOUDINARY_API_KEY=<api-key>
CLOUDINARY_API_SECRET=<api-secret>

# Frontend URL (for CORS and email links)
CLIENT_URL=http://localhost:5173

# File Upload
MAX_FILE_SIZE=10485760

# Seeder (node src/seeders/index.js) — the seeder WIPES all collections before inserting.
# SEED_DEMO: include the sample demo dataset + shared-password (Admin@123) accounts.
#   Defaults ON outside production; in production it is OFF unless set to true.
# SEED_CONFIRM: required (=true) to let the seeder run at all when NODE_ENV=production.
# SEED_ADMIN_EMAIL / SEED_ADMIN_PASSWORD: when SEED_DEMO is off, bootstrap a single real
#   super-admin instead of the demo accounts.
SEED_DEMO=true
# SEED_CONFIRM=true
# SEED_ADMIN_EMAIL=admin@yourdomain.gov.ph
# SEED_ADMIN_PASSWORD=<strong-unique-password>
